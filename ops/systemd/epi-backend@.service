[Unit]
Description=EPI Backend (Express + SQLite)
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=%h/Earnapp-manager/backend
Environment=NODE_ENV=production
Environment=PORT=4000
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=5
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
